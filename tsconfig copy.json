{
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "experimentalDecorators": true,
    "removeComments": true,
    "importHelpers": false,
    "noEmit": true,
    "module": "CommonJS",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "allowSyntheticDefaultImports": true,
    "incremental": true,
    "moduleResolution": "node",
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "react": [
        "./node_modules/@types/react"
      ],
      "@anupheaus/common": [
        "../common/src",
      ],
    },
    "lib": [
      "DOM",
      "ES2020",
      "ES2021",
      "ESNext.AsyncIterable"
    ],
    "target": "ES2022",
    "sourceMap": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src/**/*",
    "../common/src/**/*",
    "../react-ui/src/**/*",
    "test/**/*",
    "types/*"
  ],
  "exclude": [
    "dist"
  ]
}