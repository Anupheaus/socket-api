    "server": "webpack --mode development --name server",
    "client": "webpack --mode development --name client",
    "test": "vitest"
  },
  "files": [
    "dist"
  ],
  "typings": "dist/index",
  "dependencies": {
    "@anupheaus/common": "^0.0.37",
